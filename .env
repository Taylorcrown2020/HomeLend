# Copy this file to ".env" and fill in your values.
# Real environment variables override anything set here.

# Required: a long random string used to sign session cookies.
SESSION_SECRET=change-me-to-a-long-random-string

# Optional: your RentCast API key. Get one (free tier = 50 calls/month) at
# https://www.rentcast.io/api  →  Dashboard  →  API Keys.
# When set, the Find-a-Home dashboard loads live for-sale listings for the ZIP
# you search. Leave blank to use the built-in sample inventory.
RENTCAST_API_KEY=